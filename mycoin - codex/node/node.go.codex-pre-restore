func NewNode(mode string, datadir string) *Node {
	os.MkdirAll(datadir, 0755)
	dbPath := filepath.Join(datadir, "chain.db")
	db := database.OpenDB(dbPath)

	target := new(big.Int)
	target.SetString(
		"00000fffffffffffffffffffffffffffffffffffffffffffffffffffffffffff",
		16,
	)

	// ==========================================
	// 馃専 鎺㈤暦鍔犵⒓锛氬湪寤虹珛 Node 涔嬪墠锛屽厛鍗拌＝灏堝爆韬垎璀夛紒
	// ==========================================
	myNodeID := rand.Uint64() // 鎶藉嚭涓€寮甸毃姗熺殑韬垎璀夎櫉纰?	// ==========================================

	n := &Node{
		Mode:    NormalizeMode(mode),
		Chain:   []*blockchain.Block{},
		Mempool: newNodeMempool(mode, db),
		UTXO:    blockchain.NewUTXOSet(db),
		Target:  target,
		Reward:  500,
		Blocks:  make(map[string]*BlockIndex), // 鉁?淇
		//	BlockIndex: make(map[string]*blockchain.Block), // 鉁?淇
		Orphans:        make(map[string][]*blockchain.Block),
		DB:             db,
		MinerResetChan: make(chan bool, 1),
		MiningEnabled:  true,
		// ==========================================
		// 馃毃 鎺㈤暦鍔犵⒓锛氱郸绡€榛炴埓涓娿€屽缈掔敓銆嶈噦绔?		// 纰轰繚瀹冧竴鍑虹敓灏辩煡閬撹嚜宸辫┎鍏堝畨闈滃悓姝ワ紒
		// ==========================================
		IsSyncing: true,        // 馃憟 寮峰埗瑷畾鐐哄悓姝ヤ腑
		SyncState: SyncHeaders, // 馃憟 瑷畾鍒濆鐙€鎱嬬偤銆屾姄鍙栨闋€?		// ==========================================
		NodeID: myNodeID,
	}

	// ==========================================================
	// 馃毃 鎺㈤暦闂滈嵉鍔犵⒓锛氭妸鍓典笘鍗€濉婅珛閫茶鎲堕珨榛炲悕绨匡紒
	// ==========================================================
	genesis := blockchain.NewGenesisBlock(target)
	gHash := hex.EncodeToString(genesis.Hash)

	n.Blocks[gHash] = &BlockIndex{
		Hash:       gHash,
		Height:     0,
		Block:      genesis,
		CumWorkInt: big.NewInt(0),
	}
	// 闋嗕究鎶?n.Best 瑷偤鍓典笘锛岄€欐ǎ鍚屾鎵嶆湁涓€鍊嬭捣榛?	n.Best = n.Blocks[gHash]
	// ==========================================================

	go n.maintainMempool()

	return n
}

