func (n *Node) appendBlock(block *blockchain.Block) {
	// 1锔忊儯 鍔犲叆涓婚摼
	n.Chain = append(n.Chain, block)

	// 2锔忊儯 鏇存柊 UTXO锛堝彧鍋氬叡璇嗙姸鎬侊級
	for _, tx := range block.Transactions {
		if !tx.IsCoinbase {
			n.UTXO.Spend(tx)
		}
		n.UTXO.Add(tx)
	}

	// 3锔忊儯 馃敟 CPFP锛歮empool rebuild锛堝叧閿級
	oldTxs := n.Mempool.Txs
	oldSources := n.Mempool.Sources // 馃専 鎺㈤暦闂滈嵉淇锛氭妸渚嗘簮韬垎璀夊悕鍐婁篃鍌欎唤璧蜂締锛?
	n.Mempool.Reset()

	for txid, txBytes := range oldTxs {
		// 馃暤锔?鏌ュ嚭閫欑瓎浜ゆ槗鐣跺垵鏄閫佷締鐨?(濡傛灉鎵句笉鍒帮紝闋愯ō鐣朵綔鏄嚜宸?n.NodeID)
		fromID := n.NodeID
		if id, exists := oldSources[txid]; exists {
			fromID = id
		}

		// 馃殌 瑁滀笂绗?4 鍊嬪弮鏁?fromID锛?		if ok := n.Mempool.AddTxRBF(txid, txBytes, n.UTXO, fromID); !ok {
			log.Println("馃Ч mempool drop after block:", txid)
		}
	}

	hashHex := hex.EncodeToString(block.Hash)

	n.DB.Put("blocks", hashHex, block.Serialize())
	n.DB.Put("meta", "best", []byte(hashHex))
}

