func (n *Node) Mine() {
	fmt.Println("馃懛 [Node] 绀﹀伐涓绘帶绋嬪紡宸插暉鍕?..")

	if n.Miner == nil {
		n.Miner = miner.NewMiner(n.MiningAddress, n)
	}

	for {
		if !n.IsMiningEnabled() {
			time.Sleep(1 * time.Second)
			continue
		}

		// 1. 鍚屾妾㈡煡
		if !n.IsSynced() {
			time.Sleep(2 * time.Second)
			continue
		}

		// 2. 鎸栫う
		newBlock := n.Miner.Mine(true)

		// 3. 铏曠悊绲愭灉
		if newBlock != nil {
            fmt.Printf("[Node] mined block candidate: height %d, hash %x\n", newBlock.Height, newBlock.Hash)

			if n.AddBlock(newBlock) {
				n.BroadcastNewBlock(newBlock)
			} else {
                fmt.Println("[Node] mined block was rejected by AddBlock; removing included transactions from the mempool")
				for _, tx := range newBlock.Transactions {
					// Coinbase 浜ゆ槗鏈締灏变笉鍦?Mempool 瑁★紝韪簡涔熸矑褰遍熆
					n.RemoveFromMempool(tx.ID)
				}
			}

			// 馃敟馃敟馃敟 闂滈嵉淇锛氭寲鍒板涔嬪緦锛屽挤鍒朵紤鎭?2 绉掞紒 馃敟馃敟馃敟
			// 閫欒兘纰轰繚缍茶矾鏈夎冻澶犳檪闁撳偝鎾紝涔熻В姹轰簡 CPU 浣旂敤鍟忛
            fmt.Println("[Node] mining cooldown (5s)...")
			time.Sleep(5 * time.Second)
		} else {
			// 琚腑鏂?(鏀跺埌鍒ヤ汉鐨勫)
			fmt.Println("馃攧 [Node] 鍋垫脯鍒伴張鏇存柊锛屾簴鍌欓噸缃う宸ョ媭鎱?..")

			// ==========================================================
			// 馃専 鎺㈤暦绲傛サ鎺掓按琛擄細鎶?MinerResetChan 鎶戒咕锛?			// ==========================================================
			// 鏃㈢劧浣犱笂闈㈡湁 GetResetChan() 鍋氫繚璀凤紝鎴戝€戠洿鎺ュ懠鍙畠
			ch := n.GetResetChan()

			// 浣跨敤闈為樆濉炶看鍦堟娊涔鹃牷閬撳収绌嶅鐨勬墍鏈?true/false 淇¤櫉
			drainedCount := 0
			for {
				select {
				case <-ch:
					drainedCount++
					// 绻肩簩鎶戒笅涓€鍊?				default:
					// 淇＄绲傛柤鎶戒咕浜嗭紒
					goto Drained
				}
			}
		Drained:
			// 濡傛灉浣犲ソ濂囨娊鎺変簡骞惧€嬶紝鍙互鍙栨秷涓嬮潰閫欒鐨勮ɑ瑙ｄ締 debug
			// fmt.Printf("馃Ч 宸叉竻绌?%d 鍊嬬澹撶殑涓柗淇¤櫉\n", drainedCount)

			// 馃洝锔?浼戞伅 0.5 绉掞紝璁?Node 鏈夋檪闁撴妸鏂板崁濉婂閫茶硣鏂欏韩
