// 娣诲姞鏂板尯鍧?// --------------------
func (n *Node) AddBlock(block *blockchain.Block) bool {
	n.mu.Lock()
	// 馃敀 鎴戝€戜緷鐒舵墜鍕曠鐞嗛帠锛屼笉浣跨敤 defer锛屽洜鐐烘垜鍊戣绮剧⒑鎺у埗 Unlock 鏅傛

	hashHex := hex.EncodeToString(block.Hash)
	prevHex := hex.EncodeToString(block.PrevHash)

	// 1. 閲嶈妾㈡煡
	if bi, exists := n.Blocks[hashHex]; exists {
		if bi.Block != nil {
			n.mu.Unlock() // 馃敁 宸茬稉鏈変簡锛屽畨鍏ㄨВ閹?			return true
		}
		// 濡傛灉鍙湁 Header 娌?Body锛屽氨绻肩簩璺戜笅鍘昏榻婂畠
	}

	// 2. 瀛ゅ厭妾㈡煡
	parentIndex, exists := n.Blocks[prevHex]
	if !exists || parentIndex.Block == nil {
		log.Printf("鈿狅笍 鐧肩従瀛ゅ: %d (缂哄皯鐖跺 %s)\n", block.Height, prevHex[:8])
		n.addOrphanLocked(block)
		n.mu.Unlock() // 馃敁 瀛樺叆瀛ゅ厭闄紝瀹夊叏瑙ｉ帠
		return false
	}

	// 3. 鏍稿績閫ｆ帴 (姝ゆ檪浠嶆寔鏈夐帠锛屼繚璀?n.Best 鍜?n.UTXO)
	success := n.connectBlock(block, parentIndex)

	if !success {
		n.mu.Unlock() // 馃敁 澶辨晽锛屽畨鍏ㄨВ閹?		return false
	}

	// ==========================================
	// 馃殌 闂滈嵉淇榛烇細鍦ㄨВ閹栧墠锛岀⒑淇濆赋鏈媭鎱嬪凡缍撳悓姝?	// ==========================================
	// 闆栫劧 connectBlock 瑁″彲鑳芥湁 Flush锛屼絾閫欒！鍋氭渶寰岀⒑瑾嶏紝纰轰繚 Kali 閲嶅暉蹇呭皪銆?	// n.UTXO.FlushToDB() // 濡傛灉 connectBlock 宸茬稉鍋氫簡锛岄€欒！鍙渷鐣?
	isMain := false
	curr := n.Best
	for curr != nil {
		if curr.Hash == hashHex {
			isMain = true
			break
		}
		curr = curr.Parent
	}

	// 4. 閲嬫斁 Node 閹?	n.mu.Unlock()

	// 5. 鐣版/瑙ｉ帠寰岀殑寰岀簩铏曠悊
	// 娓呯悊 Mempool (姝ゆ檪鏂板崁濉婂凡鎺ヤ笂锛孧empool 鍏х殑浜ゆ槗宸插け鏁?
	n.removeConfirmedTxs(block)

	// 铏曠悊瀛ゅ厭濉婏細閫欐渻鍟熷嫊閬炶看锛屽洜鐐洪帠宸叉斁闁嬶紝涓嶆渻鐧肩敓姝婚帠
	go n.attachOrphans(hashHex)

	go indexer.IndexBlock(block, block.Height, isMain)

	if block.Height > 0 && block.Height%100 == 0 && n.SyncState == SyncSynced {
		go n.PruneBlocks()
	}

	return true
}

