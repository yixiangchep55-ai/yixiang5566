// 鏀惧湪 mycoin/node/node.go 涓?
func (n *Node) Start() {

	fmt.Println("馃殌 Node starting...")

	// -----------------------------------------
	// 1锔忊儯 璁€鍙?best锛堟鏌?DB 鏄惁瀛樺湪鍗€濉婏級
	// -----------------------------------------
	bestHashBytes := n.DB.Get("meta", "best")
	if bestHashBytes == nil {
		fmt.Println("馃摝 No existing blockchain found. Creating genesis...")
		n.initGenesis()
		return
	}
	bestHash := string(bestHashBytes)

	// -----------------------------------------
	// 2锔忊儯 寰?index bucket 鍔犺級鎵€鏈?BlockIndex
	// -----------------------------------------
	indexes := make(map[string]*BlockIndex)

	n.DB.Iterate("index", func(k, v []byte) {
		var bi BlockIndex
		json.Unmarshal(v, &bi)
		indexes[bi.Hash] = &bi
	})

	if len(indexes) == 0 {
		fmt.Println("鈿狅笍 璀﹀憡锛氳硣鏂欏韩 meta 鏈夌磤閷勶紝浣?index 鏄┖鐨勶紒")
		fmt.Println("馃攧 鑷嫊閲嶇疆鍓典笘鍗€濉?..")
		n.DB.Delete("meta", "best") // reset broken metadata before recreating genesis
		n.Blocks = make(map[string]*BlockIndex)
		n.Chain = nil
		n.UTXO = blockchain.NewUTXOSet(n.DB)
		n.initGenesis()
		return
	}

	// 瑁滃洖 big.Int
	for _, bi := range indexes {
		bi.CumWorkInt = new(big.Int)
		if bi.CumWork != "" {
			bi.CumWorkInt.SetString(bi.CumWork, 16) // 鉁?纰轰繚閫欒！鏄?16
		} else {
			bi.CumWorkInt.SetInt64(0)
		}
	}

	// -----------------------------------------
	// 3锔忊儯 鍔犺級 Block 鏈珨
	// -----------------------------------------
	for _, bi := range indexes {
		raw := n.DB.Get("blocks", bi.Hash)
		if raw != nil {
			blk, err := blockchain.DeserializeBlock(raw)
			if err == nil {
				bi.Block = blk
				bi.Timestamp = blk.Timestamp
				bi.Bits = blk.Bits
				bi.Nonce = blk.Nonce
				bi.MerkleRoot = hex.EncodeToString(blk.MerkleRoot)
			}
		}
	}

	// -----------------------------------------
	// 4锔忊儯 閲嶅缓鐖跺瓙闂滀總
	// -----------------------------------------
	for _, bi := range indexes {
		if bi.PrevHash != "" {
			parent := indexes[bi.PrevHash]
			if parent != nil {
				bi.Parent = parent
				parent.Children = append(parent.Children, bi)
			}
		}
	}

	// -----------------------------------------
	// 5锔忊儯 纰哄畾 best index (鏈€闂滈嵉鐨勯槻宕╂桨榛?
	// -----------------------------------------
	bestIndex := indexes[bestHash]
	if bestIndex == nil || bestIndex.Block == nil {
		fmt.Printf("warning: best block metadata is missing or incomplete (%s), rebuilding from index\n", bestHash)

		for _, bi := range indexes {
			if bi == nil || bi.Block == nil {
				continue
			}

			if bestIndex == nil || bestIndex.Block == nil {
				bestIndex = bi
				continue
			}

			workCmp := bi.CumWorkInt.Cmp(bestIndex.CumWorkInt)
			if workCmp > 0 || (workCmp == 0 && bi.Height > bestIndex.Height) {
				bestIndex = bi
			}
		}

		if bestIndex != nil && bestIndex.Block != nil {
			n.DB.Put("meta", "best", []byte(bestIndex.Hash))
			fmt.Printf("repaired best block to %s at height %d\n", bestIndex.Hash, bestIndex.Height)
		}
	}

	// 馃敟馃敟馃敟 绲曞皪闃茬Ζ锛氬鏋滈€欒！鏄?nil锛岀洿鎺ラ噸缃紝涓嶅噯寰€涓嬭窇锛?馃敟馃敟馃敟
	if bestIndex == nil || bestIndex.Block == nil {
		fmt.Printf("鉂?[Fatal] 璩囨枡搴悕澹烇細鎵句笉鍒?BestBlock (Hash: %s)\n", bestHash)
		fmt.Println("馃Ч 姝ｅ湪娓呴櫎閷鐨?meta 妯欑堡锛岃珛閲嶆柊鍟熷嫊绡€榛?..")
		n.DB.Delete("meta", "best")
		n.Blocks = make(map[string]*BlockIndex)
		n.Chain = nil
		n.UTXO = blockchain.NewUTXOSet(n.DB)
		n.initGenesis()
		return // 馃憟 寮峰埗绲愭潫锛岄槻姝㈠緦闈㈠牨閷?	}

	n.Best = bestIndex
	n.Blocks = indexes

	// -----------------------------------------
	// 6锔忊儯 閲嶅缓閺?	// -----------------------------------------
	var chain []*blockchain.Block
	cur := bestIndex

	for cur != nil {
		if cur.Block != nil {
			chain = append([]*blockchain.Block{cur.Block}, chain...)
		}
		cur = cur.Parent
	}

	n.Chain = chain

	// 閫欒！灏辨槸浣犲師鏈牨閷殑 466 琛岋紝鐝惧湪 bestIndex 绲曞皪涓嶅彲鑳芥槸 nil 浜?	fmt.Printf("馃彈  Loaded %d blocks from DB. Best height = %d\n",
		len(chain), bestIndex.Height)

	// ... (寰岄潰鐨?UTXO 鍜?Mempool 鍔犺級浠ｇ⒓淇濇寔涓嶈畩) ...
	// 璜嬬⒑瑾嶅緦闈㈤倓鏈夊姞杓?UTXO 鍜?Mempool 鐨勪唬纰硷紝涓嶈婕忔帀浜?
	// -----------------------------------------
	// 7锔忊儯 閲嶅缓 UTXO
	// -----------------------------------------
	n.UTXO = blockchain.NewUTXOSet(n.DB)
	n.DB.Iterate("utxo", func(k, v []byte) {
		var u blockchain.UTXO
		if err := json.Unmarshal(v, &u); err != nil {
			return
		}

		key := string(k)
		n.UTXO.Set[key] = u
		n.UTXO.AddrIndex[u.To] = append(n.UTXO.AddrIndex[u.To], key)
	})
	// ... (Mempool 鍒濆浠ｇ⒓) ...
	n.Mempool = newNodeMempool(n.Mode, n.DB)
	n.loadMempool()
	n.IsSyncing = true

	// ... (鐙€鎱嬭ō瀹? ...
	if n.Best == nil || n.Best.Height == 0 {
		n.SyncState = SyncIBD
		fmt.Println("馃啎 Fresh node, starting IBD...")
	} else {
		n.SyncState = SyncHeaders
		fmt.Printf("馃摜 Resuming sync from height %d...\n", n.Best.Height)
	}

	fmt.Println("鉁?Node is ready and searching for peers...")
}
func (n *Node) initGenesis() {
	genesis := blockchain.NewGenesisBlock(n.Target)

	// =========================================================
	// 馃敟 绗﹀悎鐝惧鐨勫娉曪細浠?Bits 鐐烘簴 (Bits as Truth) 馃敟
	// =========================================================

	// 鍗充娇鎴戝€戞槸鍓典笘鑰咃紝鎴戝€戜篃瑕佹ā鎿€屽緸缍茶矾涓婃敹鍒伴€欏€嬪崁濉娿€嶇殑閬庣▼銆?	// 鎴戝€戝皣 Bits 閭勫師鐐?big.Int锛岄€欐渻涓熷け鏈綅鐨勭簿搴︼紝浣嗚繖鎵嶆槸鍏ㄧ恫鍏辫瓨鐨?Target銆?	consensusTarget := utils.CompactToBig(genesis.Bits)

	// 浣跨敤閫欏€嬨€屽叡璀?Target銆嶄締瑷堢畻宸ヤ綔閲?	work := computeWork(consensusTarget)

	// =========================================================

	hashHex := hex.EncodeToString(genesis.Hash)
	// 馃敶 鏍稿績淇敼锛氱‘淇?bi 缁撴瀯浣撳寘鍚簡 Block 鏈綋
	bi := &BlockIndex{
		Block:      genesis, // 鎸傝浇鏈綋
		Hash:       hashHex,
		Height:     0,
		CumWork:    work.Text(16),
		CumWorkInt: work,
		Parent:     nil,
		Children:   []*BlockIndex{}, // 鍏绘垚鍒濆鍖栧垏鐗囩殑濂戒範鎯?
		Bits:       genesis.Bits,
		Timestamp:  genesis.Timestamp,
		Nonce:      genesis.Nonce,
		MerkleRoot: hex.EncodeToString(genesis.MerkleRoot),
	}

	// --- 鍐欏叆鏁版嵁搴?---
	n.DB.Put("blocks", hashHex, genesis.Serialize())

	idxBytes, _ := json.Marshal(bi)
	n.DB.Put("index", hashHex, idxBytes)

	n.DB.Put("meta", "best", []byte(hashHex))

	// ---------------------------------------------------------
	// 馃敶 鍏抽敭淇敼鐐癸細鍙繚鐣欎竴涓?Map 鐨勫啓鍏?	// ---------------------------------------------------------

	// 鍐欏叆鍞竴绱㈠紩搴?(BlockIndex 鍐呴儴宸茬粡鎸佹湁 genesis 鎸囬拡)
	n.Blocks[hashHex] = bi

	// 鉂?鍒犳帀杩欒锛歯.BlockIndex[hashHex] = genesis

	n.Best = bi

	// 涓婚摼瑙嗗浘 (濡傛灉浣犱緷鐒舵兂淇濈暀 n.Chain 杩欎釜鍒囩墖鐨勮瘽)
	n.Chain = []*blockchain.Block{genesis}

	// 鏇存柊 UTXO
	n.UTXO.Add(genesis.Transactions[0])

	fmt.Println("馃獝 Genesis block created.")
	fmt.Printf("馃攳 [Init] Genesis Bits: %d (闋愭湡: 504365055)\n", bi.Bits)
	fmt.Println("GENESIS TARGET =", utils.FormatTargetHex(genesis.Target))
}

