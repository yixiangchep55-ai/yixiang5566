func (n *Node) AddTx(tx blockchain.Transaction, fromNodeID uint64) bool {
	if debugMempoolFlow {
		fmt.Println("馃憠 [X-Ray] 婧栧倷閹栧畾 n.mu 澶ч杸...")
	}
	n.mu.Lock()
	defer n.mu.Unlock()
	if debugMempoolFlow {
		fmt.Println("馃憠 [X-Ray] 鎴愬姛閹栧畾 n.mu锛岄枊濮嬪煼琛屼繚鍏ㄦ鏌?..")
	}

	// ==========================================
	// 馃暤锔?绗竴闂滐細闁€鍙ｄ繚鍏?(鎵嬬簩璨绘鏌?
	// ==========================================
	// 娉ㄦ剰锛氶€欒！鐩存帴寰炵暥鍓?UTXO Set 鏌ユ墜绾岃不
	fee := tx.Fee(n.UTXO, n.Mempool.Txs)
	const MinRelayFee = 1 // 鍙湁鎵嬬簩璨?>= 1 鍏冩墠鍑嗛€蹭締

	if fee < MinRelayFee {
		fmt.Printf("馃毇 [Security] 浜ゆ槗 %s 鎵嬬簩璨诲お浣?(%d < %d)锛岀洿鎺ュ湪闁€澶栬涪鎺夛紒\n", tx.ID[:8], fee, MinRelayFee)
		return false
	}

	if err := VerifyTx(tx, n.UTXO, n.Mempool.Txs); err != nil {
		fmt.Printf("鉂?浜ゆ槗椹楄瓑澶辨晽琚嫆绲?(%s): %v\n", tx.ID, err)
		return false
	}

	if debugMempoolFlow {
		fmt.Println("馃憠 [X-Ray] VerifyTx 閫氶亷锛岄枊濮嬪煼琛?Mempool.Has...")
	}
	if n.Mempool.Has(tx.ID) {
		return false
	}

	if debugMempoolFlow {
		fmt.Println("馃憠 [X-Ray] Mempool.Has 閫氶亷锛岄枊濮嬪煼琛?Mempool.HasDoubleSpend...")
	}
	if n.Mempool.HasDoubleSpend(&tx) {
        fmt.Printf("[Mempool] rejecting tx %s because it conflicts with an existing mempool spend\n", tx.ID)
		return false
	}

	if debugMempoolFlow {
        fmt.Println("[X-Ray] Mempool.HasDoubleSpend passed; calling AddTxRBF...")
	}
	ok := n.Mempool.AddTxRBF(tx.ID, tx.Serialize(), n.UTXO, fromNodeID)

	if debugMempoolFlow {
        fmt.Println("[X-Ray] AddTxRBF returned")
	}
	if !ok {
        fmt.Println("[Mempool] transaction was rejected by AddTxRBF")
		return false
	}

	if debugMempoolFlow {
		fmt.Printf("馃摜 鉁?[X-Ray] 浜ゆ槗 %s 鎴愬姛閫插叆 Mempool锛岀瓑寰呮墦鍖匼n", tx.ID)
	}

	return true

}

