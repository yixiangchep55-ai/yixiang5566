// RebuildUTXO rebuilds the full UTXO set from the chain stored in n.Chain.
func (n *Node) RebuildUTXO() error {
	n.mu.Lock() // 馃毃 閫欒！瑕侀帠浣忥紝纰轰繚閲嶅缓鏅傛矑浜轰簜鍕曞赋鏈?	defer n.mu.Unlock()
    fmt.Println("[Full Rebuild] Starting full ledger rebuild...")

	// 0锔忊儯 鏍稿績闃茶锛氱⒑淇濅富閺堣鍦栨槸鏈€鏂扮殑
	n.UpdateChainFromBest()
	if n.IsPrunedMode() && len(n.Chain) > 0 && n.Chain[0] != nil && n.Chain[0].Height != 0 {
        fmt.Printf("[Full Rebuild] Pruned mode only keeps full block bodies from height %d onward; reusing the existing UTXO state.\n", n.Chain[0].Height)
		return nil
	}

	// 1锔忊儯 鍓靛缓涓€鍊嬨€岀磾瑷樻喍楂斻€嶇殑鑷ㄦ檪甯虫湰 (涓嶈鍌冲叆 DB)
	// 閫欐ǎ鍦ㄩ亶姝峰崁濉婃檪锛孲pend 鍜?Add 鍙渻鏀硅鎲堕珨锛屼笉鏈冮牷绻佸纭
	tmpUtxo := blockchain.NewUTXOSet(nil)

	// 2锔忊儯 閬嶆涓婚張
	txCount := 0
	var prevBlock *blockchain.Block
	for _, block := range n.Chain {
		if block == nil {
			continue
		}

		if err := VerifyBlockWithUTXO(block, prevBlock, tmpUtxo); err != nil {
			return fmt.Errorf("chain validation failed at height %d: %w", block.Height, err)
		}

		for _, tx := range block.Transactions {
			if !tx.IsCoinbase {
				if err := tmpUtxo.Spend(tx); err != nil {
					return fmt.Errorf("failed to apply tx %s at height %d: %w", tx.ID, block.Height, err)
				}
			}
			tmpUtxo.Add(tx)
			txCount++
		}

		prevBlock = block
	}

	// 3锔忊儯 婧栧倷鍒囨彌锛氬皣鑷ㄦ檪甯虫湰閲嶆柊闂滆伅鍒版寮?DB
	tmpUtxo.DB = n.DB

    fmt.Printf("[Full Rebuild] Rebuild complete (%d transactions). Flushing batched state to disk...\n", txCount)
	tmpUtxo.FlushToDB()

	// 5锔忊儯 鏇挎彌姝ｅ紡鎸囨
	n.UTXO = tmpUtxo

    fmt.Println("[Full Rebuild] Rebuild succeeded. Ledger state is fully synchronized.")
	return nil
}

