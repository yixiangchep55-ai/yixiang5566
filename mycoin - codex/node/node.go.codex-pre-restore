func (n *Node) rebuildChain(oldChain, newChain []*BlockIndex, newTip *BlockIndex) {
	fmt.Printf("馃攧 [Reorg] 鍟熷嫊閺堥噸绲勶細鑸婇張闀峰害 %d -> 鏂伴張闀峰害 %d\n", len(oldChain), len(newChain))

	// ============================================================
	// 馃洜锔?鏍稿績淇锛氬悓姝ユ洿鏂?UTXO 甯虫湰 (蹇呴爤鍦ㄦ洿鏂?n.Chain 涔嬪墠铏曠悊)
	// ============================================================

	// A. 鎾ら姺鑸婇張 (Rollback) - 蹇呴爤鐢辨柊寰€鑸婏紙Tip 寰€鍥炶蛋锛夋挙閵?	for i := len(oldChain) - 1; i >= 0; i-- {
		oldBI := oldChain[i]
		if oldBI != nil && oldBI.Block != nil {
			fmt.Printf("鈴?姝ｅ湪鎾ら姺鑸婇張鍗€濉? %d (Hash: %s)\n", oldBI.Height, oldBI.Hash[:8])
			for _, tx := range oldBI.Block.Transactions {
				n.UTXO.Revert(tx)
			}
			// 馃殌 銆愭墜琛撳垁 1銆戯細鍚屾鎶归櫎 PostgreSQL 瑁＄殑骞介潏鏁告摎
			indexer.UnindexBlock(oldBI.Hash)
		}
	}

	// B. 鍩疯鏂伴張 (Apply) - 蹇呴爤鐢辫垔寰€鏂帮紙楂樺害寰炲皬鍒板ぇ锛夊煼琛?	for _, newBI := range newChain {
		if newBI != nil && newBI.Block != nil {
			fmt.Printf("鈴?姝ｅ湪鍩疯鏂伴張鍗€濉? %d (Hash: %s)\n", newBI.Height, newBI.Hash[:8])
			for _, tx := range newBI.Block.Transactions {
				if !tx.IsCoinbase {
					n.UTXO.Spend(tx)
				}
				n.UTXO.Add(tx)
			}
			// 馃殌 銆愭墜琛撳垁 2銆戯細鎶婃柊閺堢殑璩囨枡閲嶆柊瀵叆 PostgreSQL锛岀⒑淇濆畠鏄渶鏂扮媭鎱?			indexer.IndexBlock(newBI.Block, newBI.Height, true)
		}
	}

	// 馃捑 纰轰繚鏇存柊寰岀殑甯虫湰鐙€鎱嬪鍏?BoltDB锛岄槻姝?Kali 閲嶅暉寰岄伜澶?	n.UTXO.FlushToDB()

	// ============================================================
	// 1锔忊儯 妲嬪缓瀹屾暣涓婚張闄ｅ垪 (鍘熷閭忚集)
	// ============================================================
	var fullChain []*blockchain.Block
	cur := newTip
	for cur != nil {
		if cur.Block != nil {
			fullChain = append([]*blockchain.Block{cur.Block}, fullChain...)
		}
		cur = cur.Parent
	}

	// 鏇存柊 Node 鏍稿績鎸囨
	n.Chain = fullChain
	n.Best = newTip

	// ============================================================
	// 2锔忊儯 鏀堕泦鏂伴張涓€愬凡缍撶⒑瑾嶃€戠殑浜ゆ槗 ID (鍘熷閭忚集)
	// ============================================================
	confirmedInNewChain := make(map[string]bool)
	for _, bi := range newChain {
		if bi != nil && bi.Block != nil {
			for _, tx := range bi.Block.Transactions {
				confirmedInNewChain[tx.ID] = true
			}
		}
	}

	// ============================================================
	// 3锔忊儯 鎵惧嚭闇€瑕侀€€鍥?Mempool 鐨勪氦鏄?(鍘熷閭忚集)
	// ============================================================
	txsToRestore := make(map[string][]byte)

	// A. 鎶撳嚭鑸婇張涓矑鏈夎鏂伴張鎵撳寘鐨勪氦鏄?	for _, old := range oldChain {
		if old != nil && old.Block != nil {
			for _, tx := range old.Block.Transactions {
				if !tx.IsCoinbase && !confirmedInNewChain[tx.ID] {
					txsToRestore[tx.ID] = tx.Serialize()
				}
			}
		}
	}

	// B. 淇濈暀鍘熸湰灏卞湪 Mempool 瑁★紝涓旀矑琚柊閺堟墦鍖呯殑浜ゆ槗
	for txid, bytes := range n.Mempool.GetAll() {
		if !confirmedInNewChain[txid] {
			txsToRestore[txid] = bytes
		}
	}

	// ============================================================
	// 4锔忊儯 瀹夊叏鍦伴噸寤?Mempool锛?(鍘熷閭忚集)
	// ============================================================
	n.Mempool.Clear()
	for txid, bytes := range txsToRestore {
		// 馃殌 闂滈嵉闃茶锛氱洿鎺ュ鍥炲簳灞?Map锛屼笉瑙哥櫦瑜囬洔椹楄瓑锛屽畬缇庨伩闁嬫閹栵紒
		n.Mempool.Txs[txid] = bytes
		n.Mempool.TotalBytes += len(bytes)
	}

	// ============================================================
	// 5锔忊儯 閲嶅缓浜ゆ槗绱㈠紩 (TxIndex) (鍘熷閭忚集)
	// ============================================================
	for _, old := range oldChain {
		if old != nil && old.Block != nil {
			n.removeTxIndex(old.Block)
		}
	}
	for _, bi := range newChain {
		if bi != nil && bi.Block != nil {
			n.indexTransactions(bi.Block, bi)
		}
	}

	log.Printf("馃攣 閺堥噸绲勫畬鎴愶紒楂樺害: %d, 宸插皣 %d 绛嗕氦鏄撻€€鍥?Mempool銆俓n", newTip.Height, len(txsToRestore))
}

