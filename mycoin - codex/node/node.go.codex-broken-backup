func (n *Node) rebuildChain(oldChain, newChain []*BlockIndex, newTip *BlockIndex) {
	fmt.Printf("棣冩敡 [Reorg] 閸熺喎瀚婇柡鍫ュ櫢缁插嫸绱伴懜濠囧嫉闂€宄板 %d -> 閺備即寮甸梹宄板 %d\n", len(oldChain), len(newChain))

	// ============================================================
	// 棣冩礈閿?閺嶇绺炬穱顔筋劀閿涙艾鎮撳銉︽纯閺?UTXO 鐢櫕婀?(韫囧懘鐖ら崷銊︽纯閺?n.Chain 娑斿澧犻搹鏇犳倞)
	// ============================================================

	// A. 閹俱倝濮洪懜濠囧嫉 (Rollback) - 韫囧懘鐖ら悽杈ㄦ煀瀵扳偓閼稿绱橳ip 瀵扳偓閸ョ偠铔嬮敍澶嬫寵闁?	for i := len(oldChain) - 1; i >= 0; i-- {
		oldBI := oldChain[i]
		if oldBI != nil && oldBI.Block != nil {
			fmt.Printf("閳?濮濓絽婀幘銈夊Ш閼稿﹪寮甸崡鈧繅? %d (Hash: %s)\n", oldBI.Height, oldBI.Hash[:8])
			for _, tx := range oldBI.Block.Transactions {
				n.UTXO.Revert(tx)
			}
			// 棣冩畬 閵嗘劖澧滅悰鎾冲瀬 1閵嗘埊绱伴崥灞绢劄閹跺綊娅?PostgreSQL 鐟侊紕娈戦獮浠嬫綇閺佸憡鎽?
			indexer.UnindexBlock(oldBI.Hash)
		}
	}

	// B. 閸╃柉顢戦弬浼村嫉 (Apply) - 韫囧懘鐖ら悽杈灁瀵扳偓閺傚府绱欐妯哄瀵扮偛鐨崚鏉裤亣閿涘鐓肩悰?	for _, newBI := range newChain {
		if newBI != nil && newBI.Block != nil {
			fmt.Printf("閳?濮濓絽婀崺鐤攽閺備即寮甸崡鈧繅? %d (Hash: %s)\n", newBI.Height, newBI.Hash[:8])
			for _, tx := range newBI.Block.Transactions {
				if !tx.IsCoinbase {
					n.UTXO.Spend(tx)
				}
				n.UTXO.Add(tx)
			}
			// 棣冩畬 閵嗘劖澧滅悰鎾冲瀬 2閵嗘埊绱伴幎濠冩煀闁哄牏娈戠挬鍥ㄦ灐闁插秵鏌婄€殿偄鍙?PostgreSQL閿涘瞼鈷戞穱婵嗙暊閺勵垱娓堕弬鎵閹?			indexer.IndexBlock(newBI.Block, newBI.Height, true)
		}
	}

	// 棣冩崙 绾拌桨绻氶弴瀛樻煀瀵板瞼娈戠敮铏拱閻欌偓閹卞顕犻崗?BoltDB閿涘矂妲诲?Kali 闁插秴鏆夊宀勪紲婢?	n.UTXO.FlushToDB()

	// ============================================================
	// 1閿斿繆鍎?濡插缂撶€瑰本鏆ｆ稉濠氬嫉闂勶絽鍨?(閸樼喎顫愰柇蹇氶泦)
	// ============================================================
	var fullChain []*blockchain.Block
	cur := newTip
	for cur != nil {
		if cur.Block != nil {
			fullChain = append([]*blockchain.Block{cur.Block}, fullChain...)
		}
		cur = cur.Parent
	}

	// 閺囧瓨鏌?Node 閺嶇绺鹃幐鍥灴
	n.Chain = fullChain
	n.Best = newTip

	// ============================================================
	// 2閿斿繆鍎?閺€鍫曟肠閺備即寮垫稉顓溾偓鎰嚒缂嶆挾鈷戠懢宥冣偓鎴犳畱娴溿倖妲?ID (閸樼喎顫愰柇蹇氶泦)
	// ============================================================
	confirmedInNewChain := make(map[string]bool)
	for _, bi := range newChain {
		if bi != nil && bi.Block != nil {
			for _, tx := range bi.Block.Transactions {
				confirmedInNewChain[tx.ID] = true
			}
		}
	}

	// ============================================================
	// 3閿斿繆鍎?閹垫儳鍤棁鈧憰渚€鈧偓閸?Mempool 閻ㄥ嫪姘﹂弰?(閸樼喎顫愰柇蹇氶泦)
	// ============================================================
	txsToRestore := make(map[string][]byte)

	// A. 閹舵挸鍤懜濠囧嫉娑擃厽鐭戦張澶庮潶閺備即寮甸幍鎾冲瘶閻ㄥ嫪姘﹂弰?	for _, old := range oldChain {
		if old != nil && old.Block != nil {
			for _, tx := range old.Block.Transactions {
				if !tx.IsCoinbase && !confirmedInNewChain[tx.ID] {
					txsToRestore[tx.ID] = tx.Serialize()
				}
			}
		}
	}

	// B. 娣囨繄鏆€閸樼喐婀扮亸鍗炴躬 Mempool 鐟佲槄绱濇稉鏃€鐭戠悮顐ｆ煀闁哄牊澧﹂崠鍛畱娴溿倖妲?
	for txid, bytes := range n.Mempool.GetAll() {
		if !confirmedInNewChain[txid] {
			txsToRestore[txid] = bytes
		}
	}

	// ============================================================
	// 4閿斿繆鍎?鐎瑰鍙忛崷浼村櫢瀵?Mempool閿?(閸樼喎顫愰柇蹇氶泦)
	// ============================================================
	n.Mempool.Clear()
	for txid, bytes := range txsToRestore {
		// 棣冩畬 闂傛粓宓夐梼鑼额劙閿涙氨娲块幒銉ヮ敚閸ョ偛绨崇仦?Map閿涘奔绗夌憴鍝ユ鐟滃洭娲旀す妤勭搼閿涘苯鐣紘搴ㄤ缉闂佸顒撮柟鏍电磼
		n.Mempool.Txs[txid] = bytes
		n.Mempool.TotalBytes += len(bytes)
	}

	// ============================================================
	// 5閿斿繆鍎?闁插秴缂撴禍銈嗘缁便垹绱?(TxIndex) (閸樼喎顫愰柇蹇氶泦)
	// ============================================================
	for _, old := range oldChain {
		if old != nil && old.Block != nil {
			n.removeTxIndex(old.Block)
		}
	}
	for _, bi := range newChain {
		if bi != nil && bi.Block != nil {
			n.indexTransactions(bi.Block, bi)
		}
	}

	log.Printf("棣冩敚 闁哄牓鍣哥徊鍕暚閹存劧绱掓妯哄: %d, 瀹告彃鐨?%d 缁涘棔姘﹂弰鎾烩偓鈧崶?Mempool閵嗕繐n", newTip.Height, len(txsToRestore))
}

