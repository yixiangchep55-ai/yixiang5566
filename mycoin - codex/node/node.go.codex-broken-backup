func (n *Node) IsOnMainChain(bi *BlockIndex) bool {
	if bi == nil || n.Best == nil || bi.Height > n.Best.Height {
		return false
	}

	// Archive 閼哄倻鍋ｉ崣顖滄纯閹恒儰绮犵€瑰本鏆ｆ稉濠氭懠鐟欏棗娴橀崨鎴掕厬閵?	if bi.Height < uint64(len(n.Chain)) {
		mainBlock := n.Chain[bi.Height]
		if mainBlock != nil && hex.EncodeToString(mainBlock.Hash) == bi.Hash {
			return true
		}
	}

	// Pruned 閼哄倻鍋ｉ惃?n.Chain 閸欘垵鍏橀崣顏冪箽閻ｆ瑦娓舵潻鎴滅濞堥潧鐤勬担鎿勭礉闁偓閸ョ偛鍩?Best 閹稿洭鎷″▽璺ㄥ煑闁炬儳娲栧┃顖氬灲閺傤厹鈧?	for cur := n.Best; cur != nil && cur.Height >= bi.Height; cur = cur.Parent {
		if cur.Height == bi.Height {
			return cur.Hash == bi.Hash
		}
	}

	return false
}

