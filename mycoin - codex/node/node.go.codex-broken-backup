func (n *Node) AddTx(tx blockchain.Transaction, fromNodeID uint64) bool {
	if debugMempoolFlow {
		fmt.Println("棣冩啝 [X-Ray] 濠ф牕鍊烽柟鏍х暰 n.mu 婢堆囨澑...")
	}
	n.mu.Lock()
	defer n.mu.Unlock()
	if debugMempoolFlow {
		fmt.Println("棣冩啝 [X-Ray] 閹存劕濮涢柟鏍х暰 n.mu閿涘矂鏋婃慨瀣吋鐞涘奔绻氶崗銊︻€侀弻?..")
	}

	// ==========================================
	// 棣冩殼閿?缁楊兛绔撮梻婊愮窗闂佲偓閸欙絼绻氶崗?(閹靛绨╃挩缁橆€侀弻?
	// ==========================================
	// 濞夈劍鍓伴敍姘垛偓娆掞紒閻╁瓨甯村鐐垫殽閸?UTXO Set 閺屻儲澧滅痪宀冧笉
	fee := tx.Fee(n.UTXO, n.Mempool.Txs)
	const MinRelayFee = 1 // 閸欘亝婀侀幍瀣癌鐠?>= 1 閸忓啯澧犻崙鍡涒偓韫窢

	if fee < MinRelayFee {
		fmt.Printf("棣冩瘒 [Security] 娴溿倖妲?%s 閹靛绨╃挩璇层亰娴?(%d < %d)閿涘瞼娲块幒銉ユ躬闂佲偓婢舵牞娑幒澶涚磼\n", tx.ID[:8], fee, MinRelayFee)
		return false
	}

	if err := VerifyTx(tx, n.UTXO, n.Mempool.Txs); err != nil {
		fmt.Printf("閴?娴溿倖妲楁す妤勭搼婢惰鲸鏅界悮顐ｅ珕缁?(%s): %v\n", tx.ID, err)
		return false
	}

	if debugMempoolFlow {
		fmt.Println("棣冩啝 [X-Ray] VerifyTx 闁岸浜烽敍宀勬瀶婵鐓肩悰?Mempool.Has...")
	}
	if n.Mempool.Has(tx.ID) {
		return false
	}

	if debugMempoolFlow {
		fmt.Println("棣冩啝 [X-Ray] Mempool.Has 闁岸浜烽敍宀勬瀶婵鐓肩悰?Mempool.HasDoubleSpend...")
	}
	if n.Mempool.HasDoubleSpend(&tx) {
        fmt.Printf("[Mempool] rejecting tx %s because it conflicts with an existing mempool spend\n", tx.ID)
		return false
	}

	if debugMempoolFlow {
        fmt.Println("[X-Ray] Mempool.HasDoubleSpend passed; calling AddTxRBF...")
	}
	ok := n.Mempool.AddTxRBF(tx.ID, tx.Serialize(), n.UTXO, fromNodeID)

	if debugMempoolFlow {
        fmt.Println("[X-Ray] AddTxRBF returned")
	}
	if !ok {
        fmt.Println("[Mempool] transaction was rejected by AddTxRBF")
		return false
	}

	if debugMempoolFlow {
		fmt.Printf("棣冩憸 閴?[X-Ray] 娴溿倖妲?%s 閹存劕濮涢柅鎻掑弳 Mempool閿涘瞼鐡戝鍛ⅵ閸栧尲n", tx.ID)
	}

	return true

}

