		} else {
			// 鐞氼偂鑵戦弬?(閺€璺哄煂閸掋儰姹夐惃鍕攺)
			fmt.Println("棣冩敡 [Node] 閸嬪灚鑴崚浼村嫉閺囧瓨鏌婇敍灞剧按閸屾瑩鍣哥純顔俱亞瀹搞儳濯幈?..")

			// ==========================================================
			// 棣冨皞 閹恒垽鏆︾徊鍌涖偟閹烘帗鎸夌悰鎿勭窗閹?MinerResetChan 閹舵垝鍜曢敍?			// ==========================================================
			// 閺冦垻鍔ф担鐘辩瑐闂堛垺婀?GetResetChan() 閸嬫矮绻氱拃鍑ょ礉閹存垵鈧垹娲块幒銉ユ嚑閸欘偄鐣?
			ch := n.GetResetChan()

			// 娴ｈ法鏁ら棃鐐烘▎婵夌偠鐪嬮崷鍫熷▕娑旈箖鐗烽柆鎾冲弾缁屽秴顥橀惃鍕閺?true/false 娣嚶ゆ珘
			drainedCount := 0
			for {
				select {
				case <-ch:
					drainedCount++
					// 缁昏偐绨╅幎鎴掔瑓娑撯偓閸?				default:
