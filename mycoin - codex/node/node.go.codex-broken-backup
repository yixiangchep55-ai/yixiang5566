func computeWork(target *big.Int) *big.Int {
	if target == nil || target.Sign() <= 0 {
		return big.NewInt(1) // 闁灝鍘ら梽銈勪簰 0 閹存牞鐭ら弫?	}

	max := new(big.Int).Lsh(big.NewInt(1), 256)
	denom := new(big.Int).Add(target, big.NewInt(1))
	work := new(big.Int).Div(max, denom)

	// 棣冩暉 娣囨繈姣嗛敍姘洤閺嬫粎鐣婚崙杞扮窢閺?0閿涘牓娲犳惔锔姐偟娴ｅ孩妾敍澶涚礉瀵嘲鍩楃徊?1
	// 闁瑦菐缁鳖垳顭銉ょ稊闁插繑澧犻張鍐杻閸旂媴绱滲est Chain 閹靛秵娓婚崚鍥ㄥ綄
	if work.Sign() == 0 {
		return big.NewInt(1)
	}
	return work
}

