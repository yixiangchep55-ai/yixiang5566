func (n *Node) SetMiningEnabled(enabled bool) bool {
	n.mu.Lock()
	changed := n.MiningEnabled != enabled
	n.MiningEnabled = enabled
	if n.MinerResetChan == nil {
		n.MinerResetChan = make(chan bool, 1)
	}
	resetChan := n.MinerResetChan
	n.mu.Unlock()

	if changed && !enabled {
		select {
		case resetChan <- true:
		default:
		}
	}

	return changed
}

