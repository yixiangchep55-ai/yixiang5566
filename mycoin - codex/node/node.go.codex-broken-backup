// 閺€鎯ф躬 mycoin/node/node.go 娑?
func (n *Node) Start() {

	fmt.Println("棣冩畬 Node starting...")

	// -----------------------------------------
	// 1閿斿繆鍎?鐠佲偓閸?best閿涘牊顎侀弻?DB 閺勵垰鎯佺€涙ê婀崡鈧繅濠忕礆
	// -----------------------------------------
	bestHashBytes := n.DB.Get("meta", "best")
	if bestHashBytes == nil {
		fmt.Println("棣冩憹 No existing blockchain found. Creating genesis...")
		n.initGenesis()
		return
	}
	bestHash := string(bestHashBytes)

	// -----------------------------------------
	// 2閿斿繆鍎?瀵?index bucket 閸旂姾绱氶幍鈧張?BlockIndex
	// -----------------------------------------
	indexes := make(map[string]*BlockIndex)

	n.DB.Iterate("index", func(k, v []byte) {
		var bi BlockIndex
		json.Unmarshal(v, &bi)
		indexes[bi.Hash] = &bi
	})

	if len(indexes) == 0 {
		fmt.Println("閳跨媴绗?鐠€锕€鎲￠敍姘崇。閺傛瑥闊?meta 閺堝纾ら柗鍕剁礉娴?index 閺勵垳鈹栭惃鍕剁磼")
		fmt.Println("棣冩敡 閼奉亜瀚婇柌宥囩枂閸撳吀绗橀崡鈧繅?..")
		n.DB.Delete("meta", "best") // reset broken metadata before recreating genesis
		n.Blocks = make(map[string]*BlockIndex)
		n.Chain = nil
		n.UTXO = blockchain.NewUTXOSet(n.DB)
		n.initGenesis()
		return
	}

	// 鐟佹粌娲?big.Int
	for _, bi := range indexes {
		bi.CumWorkInt = new(big.Int)
		if bi.CumWork != "" {
			bi.CumWorkInt.SetString(bi.CumWork, 16) // 閴?绾拌桨绻氶柅娆掞紒閺?16
		} else {
			bi.CumWorkInt.SetInt64(0)
		}
	}

	// -----------------------------------------
	// 3閿斿繆鍎?閸旂姾绱?Block 閺堫剟鐝?
	// -----------------------------------------
	for _, bi := range indexes {
		raw := n.DB.Get("blocks", bi.Hash)
		if raw != nil {
			blk, err := blockchain.DeserializeBlock(raw)
			if err == nil {
				bi.Block = blk
				bi.Timestamp = blk.Timestamp
				bi.Bits = blk.Bits
				bi.Nonce = blk.Nonce
				bi.MerkleRoot = hex.EncodeToString(blk.MerkleRoot)
			}
		}
	}

	// -----------------------------------------
	// 4閿斿繆鍎?闁插秴缂撻悥璺虹摍闂傛粈绺?
	// -----------------------------------------
	for _, bi := range indexes {
		if bi.PrevHash != "" {
			parent := indexes[bi.PrevHash]
			if parent != nil {
				bi.Parent = parent
				parent.Children = append(parent.Children, bi)
			}
		}
	}

	// -----------------------------------------
	// 5閿斿繆鍎?绾板搫鐣?best index (閺堚偓闂傛粓宓夐惃鍕Щ瀹曗晜妗ㄦ?
	// -----------------------------------------
	bestIndex := indexes[bestHash]
	if bestIndex == nil || bestIndex.Block == nil {
		fmt.Printf("warning: best block metadata is missing or incomplete (%s), rebuilding from index\n", bestHash)

		for _, bi := range indexes {
			if bi == nil || bi.Block == nil {
				continue
			}

			if bestIndex == nil || bestIndex.Block == nil {
				bestIndex = bi
				continue
			}

			workCmp := bi.CumWorkInt.Cmp(bestIndex.CumWorkInt)
			if workCmp > 0 || (workCmp == 0 && bi.Height > bestIndex.Height) {
				bestIndex = bi
			}
		}

		if bestIndex != nil && bestIndex.Block != nil {
			n.DB.Put("meta", "best", []byte(bestIndex.Hash))
			fmt.Printf("repaired best block to %s at height %d\n", bestIndex.Hash, bestIndex.Height)
		}
	}

	// 棣冩暉棣冩暉棣冩暉 缁叉洖鐨梼鑼栭敍姘洤閺嬫粓鈧瑨锛侀弰?nil閿涘瞼娲块幒銉╁櫢缂冾噯绱濇稉宥呭櫙瀵扳偓娑撳绐囬敍?棣冩暉棣冩暉棣冩暉
	if bestIndex == nil || bestIndex.Block == nil {
		fmt.Printf("閴?[Fatal] 鐠╁洦鏋℃惔顐ｆ倳婢圭儑绱伴幍鍙ョ瑝閸?BestBlock (Hash: %s)\n", bestHash)
		fmt.Println("棣冃?濮濓絽婀〒鍛存珟闁奉垵顎冮惃?meta 濡瑧鍫￠敍宀冪彌闁插秵鏌婇崯鐔峰珚缁♀偓姒?..")
		n.DB.Delete("meta", "best")
		n.Blocks = make(map[string]*BlockIndex)
		n.Chain = nil
		n.UTXO = blockchain.NewUTXOSet(n.DB)
		n.initGenesis()
		return // 棣冩啛 瀵嘲鍩楃徊鎰将閿涘矂妲诲銏犵乏闂堛垹鐗ㄩ柗?	}

	n.Best = bestIndex
	n.Blocks = indexes

	// -----------------------------------------
	// 6閿斿繆鍎?闁插秴缂撻柡?	// -----------------------------------------
	var chain []*blockchain.Block
	cur := bestIndex

	for cur != nil {
		if cur.Block != nil {
			chain = append([]*blockchain.Block{cur.Block}, chain...)
		}
		cur = cur.Parent
	}

	n.Chain = chain

	// 闁瑨锛佺亸杈ㄦЦ娴ｇ姴甯張顒€鐗ㄩ柗顖滄畱 466 鐞涘矉绱濋悵鎯ф躬 bestIndex 缁叉洖鐨稉宥呭讲閼宠姤妲?nil 娴?	fmt.Printf("棣冨綀  Loaded %d blocks from DB. Best height = %d\n",
		len(chain), bestIndex.Height)

	// ... (瀵板矂娼伴惃?UTXO 閸?Mempool 閸旂姾绱氭禒锝団挀娣囨繃瀵旀稉宥堢暕) ...
	// 鐠滃鈷戠懢宥呯乏闂堛垽鍊撻張澶婂鏉?UTXO 閸?Mempool 閻ㄥ嫪鍞喊纭风礉娑撳秷顩﹀蹇斿竴娴?
	// -----------------------------------------
	// 7閿斿繆鍎?闁插秴缂?UTXO
	// -----------------------------------------
	n.UTXO = blockchain.NewUTXOSet(n.DB)
	n.DB.Iterate("utxo", func(k, v []byte) {
		var u blockchain.UTXO
		if err := json.Unmarshal(v, &u); err != nil {
			return
		}

		key := string(k)
		n.UTXO.Set[key] = u
		n.UTXO.AddrIndex[u.To] = append(n.UTXO.AddrIndex[u.To], key)
	})
	// ... (Mempool 閸掓繂顫愭禒锝団挀) ...
	n.Mempool = newNodeMempool(n.Mode, n.DB)
	n.loadMempool()
	n.IsSyncing = true

	// ... (閻欌偓閹卞艒鐎? ...
	if n.Best == nil || n.Best.Height == 0 {
		n.SyncState = SyncIBD
		fmt.Println("棣冨晭 Fresh node, starting IBD...")
	} else {
		n.SyncState = SyncHeaders
		fmt.Printf("棣冩憸 Resuming sync from height %d...\n", n.Best.Height)
	}

	fmt.Println("閴?Node is ready and searching for peers...")
}
func (n *Node) initGenesis() {
	genesis := blockchain.NewGenesisBlock(n.Target)

	// =========================================================
	// 棣冩暉 缁楋箑鎮庨悵鎯ь嚊閻ㄥ嫬顕犲▔鏇窗娴?Bits 閻愮儤绨?(Bits as Truth) 棣冩暉
	// =========================================================

	// 閸楀厖濞囬幋鎴濃偓鎴炴Ц閸撳吀绗橀懓鍜冪礉閹存垵鈧垳绡冪憰浣鼓侀幙顑锯偓灞界犯缂嶈尪鐭炬稉濠冩暪閸掍即鈧瑥鈧宕佹繅濞库偓宥囨畱闁海鈻奸妴?	// 閹存垵鈧垵鐨?Bits 闁嫬甯悙?big.Int閿涘矂鈧瑦娓绘稉鐔枫亼閺堫偂缍呴惃鍕翱鎼达讣绱濇担鍡氱箹閹靛秵妲搁崗銊ф伀閸忚精鐡ㄩ惃?Target閵?	consensusTarget := utils.CompactToBig(genesis.Bits)

	// 娴ｈ法鏁ら柅娆忊偓瀣ㄢ偓灞藉彙鐠€?Target閵嗗秳绶犵懛鍫㈢暬瀹搞儰缍旈柌?	work := computeWork(consensusTarget)

	// =========================================================

	hashHex := hex.EncodeToString(genesis.Hash)
	// 棣冩暥 閺嶇绺炬穱顔芥暭閿涙氨鈥樻穱?bi 缂佹挻鐎担鎾冲瘶閸氼偂绨?Block 閺堫兛缍?
	bi := &BlockIndex{
		Block:      genesis, // 閹稿倽娴囬張顑跨秼
		Hash:       hashHex,
		Height:     0,
		CumWork:    work.Text(16),
		CumWorkInt: work,
		Parent:     nil,
		Children:   []*BlockIndex{}, // 閸忕粯鍨氶崚婵嗩潗閸栨牕鍨忛悧鍥╂畱婵傛垝绡勯幆?
		Bits:       genesis.Bits,
		Timestamp:  genesis.Timestamp,
		Nonce:      genesis.Nonce,
		MerkleRoot: hex.EncodeToString(genesis.MerkleRoot),
	}

	// --- 閸愭瑥鍙嗛弫鐗堝祦鎼?---
	n.DB.Put("blocks", hashHex, genesis.Serialize())

	idxBytes, _ := json.Marshal(bi)
	n.DB.Put("index", hashHex, idxBytes)

	n.DB.Put("meta", "best", []byte(hashHex))

	// ---------------------------------------------------------
	// 棣冩暥 閸忔娊鏁穱顔芥暭閻愮櫢绱伴崣顏冪箽閻ｆ瑤绔存稉?Map 閻ㄥ嫬鍟撻崗?	// ---------------------------------------------------------

