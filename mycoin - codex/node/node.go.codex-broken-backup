		n.mu.Unlock() // 棣冩晛 鐎涙ê鍙嗙€涖倕鍘梽顫礉鐎瑰鍙忕憴锝夊笭
		return false
	}

	// 3. 閺嶇绺鹃柅锝嗗复 (濮濄倖妾禒宥嗗瘮閺堝甯犻敍灞肩箽鐠€?n.Best 閸?n.UTXO)
	success := n.connectBlock(block, parentIndex)

	if !success {
		n.mu.Unlock() // 棣冩晛 婢惰鲸鏅介敍灞界暔閸忋劏袙闁?		return false
	}

	// ==========================================
	// 棣冩畬 闂傛粓宓夋穱顔筋劀姒涚儑绱伴崷銊ㄐ掗柟鏍у閿涘瞼鈷戞穱婵嗚祴閺堫剛濯幈瀣嚒缂嶆挸鎮撳?	// ==========================================
	// 闂嗘牜鍔?connectBlock 鐟佲€冲讲閼宠姤婀?Flush閿涘奔绲鹃柅娆掞紒閸嬫碍娓跺宀€鈷戠懢宥忕礉绾拌桨绻?Kali 闁插秴鏆夎箛鍛毆閵?	// n.UTXO.FlushToDB() // 婵″倹鐏?connectBlock 瀹歌尙绋夐崑姘啊閿涘矂鈧瑨锛侀崣顖滄阜閻?
	isMain := false
	curr := n.Best
	for curr != nil {
		if curr.Hash == hashHex {
			isMain = true
			break
		}
		curr = curr.Parent
	}

	// 4. 闁插鏂?Node 闁?	n.mu.Unlock()

	// 5. 閻ｇ増顒?鐟欙綁甯犲宀€娈戝宀€绨╅搹鏇犳倞
	// 濞撳懐鎮?Mempool (濮濄倖妾弬鏉垮磥婵夊﹤鍑￠幒銉ょ瑐閿涘empool 閸徰呮畱娴溿倖妲楀鎻掋亼閺?
	n.removeConfirmedTxs(block)

	// 閾忔洜鎮婄€涖倕鍘繅濠忕窗闁瑦娓婚崯鐔峰珚闁偠鐪嬮敍灞芥礈閻愭椽甯犲鍙夋杹闂佸绱濇稉宥嗘富閻ц偐鏁撳濠氬笭
	go n.attachOrphans(hashHex)

	go indexer.IndexBlock(block, block.Height, isMain)

	if block.Height > 0 && block.Height%100 == 0 && n.SyncState == SyncSynced {
		go n.PruneBlocks()
	}

	return true
}

