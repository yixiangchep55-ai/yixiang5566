	key := hex.EncodeToString(hash)

	n.mu.Lock()
	defer n.mu.Unlock()

	// 1. 濡偓閺屻儳鍌ㄥ鏇熸Ц閸氾箑鐡ㄩ崷?	bi, exists := n.Blocks[key]
	if exists {
